# Copy this file to .env and fill in real values
# NEVER commit .env to version control

# Hosting / Reverse Proxy
DOMAIN=bfpacs.tech
TLS_EMAIL=your@real-email.com

# Database
DB_PASSWORD=your_secure_password_here
DATABASE_URL=postgres://bfp_admin:${DB_PASSWORD}@localhost:5433/bfpacs_db

# Authentication
JWT_SECRET=generate_a_random_64_char_secret_here

# App mode (release | debug)
GIN_MODE=release

# Build-time API URL
VITE_API_URL=/api/v1
